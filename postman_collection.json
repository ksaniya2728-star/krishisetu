{
  "info": {
    "name": "FarmBridge / KrishiSetu API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ramesh Kumar\",\n  \"phoneNumber\": \"9876543210\",\n  \"password\": \"123456\",\n  \"role\": \"farmer\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/auth/signup", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneOrEmail\": \"9876543210\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/auth/profile", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "profile"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/auth/logout", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "logout"] }
          }
        },
        {
          "name": "Onboarding",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmName\": \"Green Acres\",\n  \"produceTypes\": [\"Tomatoes\"]\n}"
            },
            "url": { "raw": "http://localhost:5000/api/auth/onboarding", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "onboarding"] }
          }
        }
      ]
    },
    {
      "name": "Farmer",
      "item": [
        {
          "name": "Add Produce",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Fresh Tomatoes\",\n  \"category\": \"Vegetables\",\n  \"pricePerKg\": 40,\n  \"stockQuantity\": 100,\n  \"harvestDate\": \"2023-11-01\",\n  \"location\": { \"type\": \"Point\", \"coordinates\": [77.5946, 12.9716] }\n}"
            },
            "url": { "raw": "http://localhost:5000/api/farmer/produce", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "farmer", "produce"] }
          }
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/farmer/orders", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "farmer", "orders"] }
          }
        }
      ]
    },
    {
      "name": "Consumer",
      "item": [
        {
          "name": "Nearby Produce",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/consumer/nearby-produce?lat=12.9716&lng=77.5946&distanceKm=20", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "consumer", "nearby-produce"], "query": [{ "key": "lat", "value": "12.9716" }, { "key": "lng", "value": "77.5946" }, { "key": "distanceKm", "value": "20" }] }
          }
        },
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartItems\": [\n    { \"produceId\": \"PRODUCE_ID_HERE\", \"quantity\": 5 }\n  ],\n  \"deliveryAddress\": \"123 Street\",\n  \"paymentMethod\": \"COD\",\n  \"deliverySlot\": \"Morning\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/consumer/place-order", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "consumer", "place-order"] }
          }
        }
      ]
    },
    {
      "name": "Distributor",
      "item": [
        {
          "name": "Get Deliveries",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/distributor/deliveries", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "distributor", "deliveries"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Order History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/orders/history", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "orders", "history"] }
          }
        }
      ]
    },
    {
      "name": "Maps",
      "item": [
        {
          "name": "Distance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceLat\": 12.9716,\n  \"sourceLng\": 77.5946,\n  \"destLat\": 13.0827,\n  \"destLng\": 80.2707\n}"
            },
            "url": { "raw": "http://localhost:5000/api/maps/distance", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "maps", "distance"] }
          }
        }
      ]
    }
  ]
}
